# List Slicing
list_of_fruits = ['apple', 'mango', 'banana', 'orange', 'grapes']
list_of_fruits[1:3]
list_of_fruits[1:] # if we miss ending_index, so it will be automatically last index.
list_of_fruits[1: len(list_of_fruits)] # if we use len so python will print till end of list.
list_of_fruits[:5] # if we miss starting_index, so it will be automatically 0.

# Negative Slicing
print(list_of_fruits)
list_of_fruits[-3 : -1] # In the negative slicing, the stating index will be greater and the ending index will be smaller.


